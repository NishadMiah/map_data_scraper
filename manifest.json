{
  "manifest_version": 3,
  "name": "G-Maps Lead Scraper & Email Finder",
  "version": "1.0.0",
  "description": "Scrapes business listings from Google Maps search results, finds emails, and exports to CSV.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open G-Maps Scraper Side Panel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "oauth2": {
    "client_id": "34750823602-b48ht3b1s4paouv2hgpt7lqmo5tfuid2.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  }
}
